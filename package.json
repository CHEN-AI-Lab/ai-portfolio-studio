{
  "name": "ai-portfolio-studio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "turbo typecheck",
    "generate:works": "node scripts/generate-works.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,scss}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "ci": "pnpm install --frozen-lockfile && turbo build",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,scss}": [
      "prettier --write"
    ]
  }
}