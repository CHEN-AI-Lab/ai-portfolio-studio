# ─── Supabase（必须配置，用于作品数据存储）───────────────────────────
# 1. 登录 supabase.com → 创建项目
# 2. Project Settings → API → 复制 Project URL 和 anon / publishable key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# ─── 上传密码（用于上传作品和管理后台的验证）─────────────────────────
UPLOAD_SECRET=your_upload_password

# ─── 七牛云 Kodo（可选，生产环境大文件存储）─────────────────────────
# 1. 注册七牛云 → 实名认证 → 创建 Bucket
# 2. 个人中心 → 密钥管理 → 拿到 AccessKey / SecretKey
QINIU_ACCESS_KEY=your_qiniu_access_key
QINIU_SECRET_KEY=your_qiniu_secret_key
QINIU_BUCKET=your-bucket-name
QINIU_DOMAIN=your-bucket.s3-cn-east-1.qiniucs.com

# ─── 网站地址（用于 SEO、API 请求）─────────────────────────────────────
SITE_URL=http://localhost:3000

# ─── 七牛云配置说明 ──────────────────────────────────────────────────
# Bucket 设置 → 绑定域名（或使用默认测试域名）
# Bucket 设置 → 权限管理 → 设为「公开」
